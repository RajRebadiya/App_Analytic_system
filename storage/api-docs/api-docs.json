{
    "openapi": "3.0.0",
    "info": {
        "title": "Multi Android App Management API",
        "version": "1.0.0"
    },
    "paths": {
        "/universal": {
            "post": {
                "tags": [
                    "Universal"
                ],
                "description": "Universal single API endpoint.\n\nActions available for module apps: list, create, show, update, delete, install, heartbeat, save-token/save-fcm.\n\nAdmin app CRUD examples:\n- List: {\"module\":\"apps\",\"action\":\"list\"}\n- Create: {\"module\":\"apps\",\"action\":\"create\",\"payload\":{\"name\":\"Jivanand\",\"package_name\":\"com.example.jivanand\",\"current_version\":\"1.0.0\"}}\n- Show: {\"module\":\"apps\",\"action\":\"show\",\"id\":2}\n- Update: {\"module\":\"apps\",\"action\":\"update\",\"id\":2,\"payload\":{\"name\":\"Jivanand\",\"package_name\":\"com.example.jivanand\",\"current_version\":\"1.0.1\"}}\n- Delete: {\"module\":\"apps\",\"action\":\"delete\"}\n\nApp credential: send app_package_name header or payload.app_package_name.\n\nInstall payload example: {\"module\":\"apps\",\"action\":\"install\",\"payload\":{\"app_package_name\":\"com.example.jivanand\",\"device_id\":\"device-12345\",\"device_name\":\"Pixel 8\",\"device_brand\":\"Google\",\"android_version\":\"15\",\"country_code\":\"IN\",\"app_version\":\"1.0.0\"}}\n\nHeartbeat payload example: {\"module\":\"apps\",\"action\":\"heartbeat\",\"payload\":{\"app_package_name\":\"com.example.jivanand\",\"device_id\":\"device-12345\",\"app_version\":\"1.0.0\"}}\n\nSave FCM token example: {\"module\":\"apps\",\"action\":\"save-token\",\"payload\":{\"app_package_name\":\"com.example.jivanand\",\"device_id\":\"device-12345\",\"fcm_token\":\"firebase-device-token\",\"is_active\":true}}",
                "operationId": "32fdd17c7a7cafddc0842897745774c5",
                "parameters": [
                    {
                        "name": "X-App-Package-Name",
                        "in": "header",
                        "description": "Optional when app_package_name is sent inside payload.",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "example": "com.example.jivanand"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UniversalRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Universal action completed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiSuccess"
                                }
                            }
                        }
                    },
                    "201": {
                        "description": "Universal resource created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiSuccess"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid app package name",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiSuccess"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation failed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    }
                },
                "servers": [
                    {
                        "url": "/api/v1"
                    }
                ]
            }
        },
        "/ad-config": {
            "get": {
                "tags": [
                    "Android App"
                ],
                "description": "Fetch Android ad config in the new mobile contract. Response data is always an array with one object.",
                "operationId": "b8732bf5584a8e344130c3d2992ade9b",
                "parameters": [
                    {
                        "name": "X-App-Package-Name",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "com.example.jivanand"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ad config fetched",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AdConfigResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid app package name",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiSuccess"
                                }
                            }
                        }
                    }
                },
                "servers": [
                    {
                        "url": "/api/v1"
                    }
                ]
            }
        },
        "/admin/ad-settings": {
            "post": {
                "tags": [
                    "Admin Ad Settings"
                ],
                "description": "Create or update ad settings. Payload accepts the same ad config keys returned to the Android app. Identify the app with app_package_name, package_name, app_db_id, or numeric app_id.",
                "operationId": "7c03e15ff27fdba417f1bb764772b90d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AdConfigPayload"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Ad settings saved",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status_code": {
                                            "type": "integer",
                                            "example": 201
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Ad settings saved"
                                        },
                                        "data": {
                                            "$ref": "#/components/schemas/AdConfigPayload"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation failed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    }
                },
                "servers": [
                    {
                        "url": "/api/v1"
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "ApiSuccess": {
                "properties": {
                    "status_code": {
                        "type": "integer",
                        "example": 200
                    },
                    "message": {
                        "type": "string",
                        "example": "Success message"
                    },
                    "data": {
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "ValidationError": {
                "properties": {
                    "status_code": {
                        "type": "integer",
                        "example": 422
                    },
                    "message": {
                        "type": "string",
                        "example": "Validation failed"
                    },
                    "errors": {
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "AdConfigPayload": {
                "properties": {

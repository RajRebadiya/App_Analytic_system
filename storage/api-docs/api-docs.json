                    },
                    "app_package_name": {
                        "type": "string",
                        "example": "com.example.jivanand"
                    },
                    "package_name": {
                        "type": "string",
                        "example": "com.appanalytics.mynewsapp.abc12345"
                    },
                    "admob_interid": {
                        "type": "string",
                        "example": "ca-app-pub-3940256099942544/1033173712"
                    },
                    "admob_bannerid": {

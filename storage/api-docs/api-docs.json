                        "items": {
                            "$ref": "#/components/schemas/AdConfigPayload"
                        }
                    }
                },
                "type": "object"
            },
            "UniversalRequest": {
                "description": "Single endpoint request. Supported actions for apps: list, create, show, update, delete, install, heartbeat, save-token. For install, heartbeat, and save-token, identify the app with app_package_name header or payload.app_package_name.",
                "required": [
                    "module",
                    "action"
                ],
                "properties": {
                    "module": {
                        "description": "Current supported module. Future modules will be added here.",
                        "type": "string",
                        "example": "apps",
                        "enum": [
                            "apps"
                        ]
                    },
                    "action": {
                        "description": "Available actions: list, create, show, update, delete, install, heartbeat, save-token.",
                        "type": "string",
                        "example": "create",
                        "enum": [
                            "list",
                            "create",
                            "show",
                            "update",
                            "delete",
                            "install",
                            "heartbeat",
                            "save-token",
                            "save-fcm"
                        ]
                    },
                    "id": {
                        "description": "Required for show, update, and delete. Can also be sent as payload.id.",
                        "type": "integer",
                        "example": 2,
                        "nullable": true
                    },
                    "payload": {
                        "description": "Action payload. create/update use name, package_name, and current_version. install uses device_id, device_name, device_brand, android_version, country_code, app_version. heartbeat uses device_id and optional app_version. save-token uses device_id, fcm_token, and optional is_active.",
                        "type": "object",
                        "example": {
                            "name": "Jivanand",
                            "package_name": "com.example.jivanand",
                            "current_version": "1.0.0"
                        }
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "AppPackageName": {
                "type": "apiKey",
                "name": "X-App-Package-Name",
                "in": "header"
            }
        }

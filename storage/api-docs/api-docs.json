{
    "openapi": "3.0.0",
    "info": {
        "title": "Multi Android App Management API",
        "version": "1.0.0"
    },
    "paths": {
        "/universal": {
            "post": {
                "tags": [
                    "Universal"
                ],
                "description": "Universal single API endpoint.\n\nActions available for module apps: list, create, show, update, delete, install, heartbeat.\n\nAdmin app CRUD examples:\n- List: {\"module\":\"apps\",\"action\":\"list\"}\n- Create: {\"module\":\"apps\",\"action\":\"create\",\"payload\":{\"name\":\"Jivanand\",\"version\":\"1.0.0\"}}\n- Show: {\"module\":\"apps\",\"action\":\"show\",\"id\":2}\n- Update: {\"module\":\"apps\",\"action\":\"update\",\"id\":2,\"payload\":{\"name\":\"Jivanand\",\"version\":\"1.1.0\"}}\n- Delete: {\"module\":\"apps\",\"action\":\"delete\",\"id\":2}\n\nInstall and heartbeat credentials:\n- Option 1 headers: X-App-Id and X-App-Key\n- Option 2 payload: app_id and api_key\n\nInstall payload example: {\"module\":\"apps\",\"action\":\"install\",\"payload\":{\"app_id\":\"jivanand-abc123\",\"api_key\":\"secret-key\",\"device_id\":\"device-12345\",\"device_name\":\"Pixel 8\",\"device_brand\":\"Google\",\"android_version\":\"15\",\"app_version\":\"1.0.0\"}}\n\nHeartbeat payload example: {\"module\":\"apps\",\"action\":\"heartbeat\",\"payload\":{\"app_id\":\"jivanand-abc123\",\"api_key\":\"secret-key\",\"device_id\":\"device-12345\",\"app_version\":\"1.0.0\"}}",
                "operationId": "32fdd17c7a7cafddc0842897745774c5",
                "parameters": [
                    {
                        "name": "X-App-Id",
                        "in": "header",
                        "description": "Optional for install/heartbeat when app_id is not sent inside payload.",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "example": "jivanand-abc123"
                    },
                    {
                        "name": "X-App-Key",
                        "in": "header",
                        "description": "Optional for install/heartbeat when api_key is not sent inside payload.",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "example": "secret-key"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UniversalRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Universal action completed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiSuccess"
                                }
                            }
                        }
                    },
                    "201": {
                        "description": "Universal resource created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiSuccess"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid app credentials",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiSuccess"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation failed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    }
                },
                "servers": [
                    {
                        "url": "/api/v1"
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "ApiSuccess": {
                "properties": {
                    "status_code": {
                        "type": "integer",
                        "example": 200
                    },
                    "message": {
                        "type": "string",
                        "example": "Success message"
                    },
                    "data": {
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "ValidationError": {
                "properties": {
                    "status_code": {
                        "type": "integer",
                        "example": 422
                    },
                    "message": {
                        "type": "string",
                        "example": "Validation failed"
                    },
                    "errors": {
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "UniversalRequest": {
                "description": "Single endpoint request. Supported actions for apps: list, create, show, update, delete, install, heartbeat. For install and heartbeat, app credentials can be sent either as headers X-App-Id and X-App-Key, or inside payload as app_id and api_key.",
                "required": [
                    "module",
                    "action"
                ],
                "properties": {
                    "module": {
                        "description": "Current supported module. Future modules will be added here.",
                        "type": "string",
                        "example": "apps",
                        "enum": [
                            "apps"
                        ]
                    },
                    "action": {
                        "description": "Available actions: list, create, show, update, delete, install, heartbeat.",
                        "type": "string",
                        "example": "create",
                        "enum": [
                            "list",
                            "create",
                            "show",
                            "update",
                            "delete",
                            "install",
                            "heartbeat"
                        ]
                    },
                    "id": {
                        "description": "Required for show, update, and delete. Can also be sent as payload.id.",
                        "type": "integer",
                        "example": 2,
                        "nullable": true
                    },
                    "payload": {
                        "description": "Action payload. create/update use name and version. install uses device_id, device_name, device_brand, android_version, app_version. heartbeat uses device_id and optional app_version. install/heartbeat may also include app_id and api_key.",
                        "type": "object",
                        "example": {
                            "name": "Jivanand",
                            "version": "1.0.0"
                        }
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "AppApiKey": {
                "type": "apiKey",
                "name": "X-App-Key",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Universal",
            "description": "Universal"
        }
    ]
}
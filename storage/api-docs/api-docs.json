                    "admob_nativeid": {
                        "type": "string",
                        "example": "ca-app-pub-3940256099942544/2247696110"
                    },
                    "admob_appopenid": {
                        "type": "string",
                        "example": "ca-app-pub-3940256099942544/9257395921"
                    },
                    "adx_inter_id": {
                        "type": "string",
                        "example": "499/example/interstitial"
                    },
                    "adx_banner_id": {
                        "type": "string",
                        "example": "499/example/adaptive-banner"
                    },
                    "adx_medium_rectangleid": {
                        "type": "string",
                        "example": "499/example/adaptive-banner"
                    },
                    "adx_native_id": {
                        "type": "string",
                        "example": "499/example/native"
                    },
                    "adx_appopen_id": {
                        "type": "string",
                        "example": "499/example/app-open"
                    },
                    "fb_inter_id": {
                        "type": "string",
                        "example": ""
                    },
                    "fb_banner_id": {
                        "type": "string",
                        "example": ""
                    },
                    "fb_medium_rectangle_id": {
                        "type": "string",
                        "example": ""
                    },
                    "fb_native_id": {
                        "type": "string",
                        "example": ""
                    },
                    "fb_native_banner_id": {
                        "type": "string",
                        "example": ""
                    },
                    "wortise_app_id": {
                        "type": "string",
                        "example": ""
                    },
                    "wortise_appopen_id": {
                        "type": "string",
                        "example": ""
                    },
                    "wortise_inter_id": {
                        "type": "string",
                        "example": ""
                    },
                    "wortise_banner_id": {
                        "type": "string",
                        "example": ""
                    },
                    "wortise_medium_rectangle_id": {
                        "type": "string",
                        "example": ""
                    },
                    "wortise_native_id": {
                        "type": "string",
                        "example": ""
                    },
                    "inter_count": {
                        "type": "string",
                        "example": "2"
